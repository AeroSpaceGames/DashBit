[sub_resource type="VisualShader" id="VisualShader_nrfil"]
code = "shader_type canvas_item;
render_mode blend_mix;

uniform vec4 Color : source_color;



void fragment() {
// Input:2
	vec4 n_out2p0 = COLOR;


// VectorOp:3
	vec3 n_in3p1 = vec3(0.00000, 1.00000, 1.00000);
	vec3 n_out3p0 = vec3(n_out2p0.xyz) * n_in3p1;


// VectorLen:4
	float n_out4p0 = length(n_out3p0);


// Step:5
	float n_in5p0 = 0.01000;
	float n_out5p0 = step(n_in5p0, n_out4p0);


// VectorOp:9
	vec3 n_out9p0 = vec3(n_out5p0) * vec3(n_out2p0.xyz);


// FloatFunc:7
	float n_out7p0 = 1.0 - n_out5p0;


// ColorParameter:6
	vec4 n_out6p0 = Color;


// VectorOp:8
	vec3 n_out8p0 = vec3(n_out7p0) * vec3(n_out6p0.xyz);


// VectorOp:10
	vec3 n_out10p0 = n_out9p0 + n_out8p0;


// Output:0
	COLOR.rgb = n_out10p0;


}
"
