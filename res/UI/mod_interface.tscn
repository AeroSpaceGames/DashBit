[connection signal="button_down" from="EditMode/Values/TitleEdit" to="." method="open_file_manager"]
[connection signal="pressed" from="EditMode/Values/HasGMPEdit" to="." method="check_gamepass"]
[connection signal="color_changed" from="EditMode/Values/GamepassContainer/MainCol/MainColor" to="." method="change_main_color"]
[connection signal="color_changed" from="EditMode/Values/GamepassContainer/UpperCol/UpperColor" to="." method="change_upper_color"]
[connection signal="color_changed" from="EditMode/Values/GamepassContainer/BottomCol/BottomColor" to="." method="change_bottom_color"]
[connection signal="value_changed" from="EditMode/Values/GamepassContainer/StepsContainer/StepsEdit" to="." method="edit_steps"]
[connection signal="value_changed" from="EditMode/Values/GamepassContainer/BigStepsContainer/LastGift" to="." method="edit_last_gift"]
[connection signal="button_down" from="EditMode/Values/GamepassContainer/NormalGift/GiftEdit" to="." method="connect_to_gift"]
[connection signal="button_down" from="EditMode/Values/GamepassContainer/NormalGift/GiftEdit" to="." method="open_res_manager"]
[connection signal="button_down" from="EditMode/Values/GamepassContainer/BigGift/BigGiftEdit" to="." method="connect_to_big_gift"]
[connection signal="button_down" from="EditMode/Values/GamepassContainer/BigGift/BigGiftEdit" to="." method="open_res_manager"]
[connection signal="value_changed" from="EditMode/Values/GamepassContainer/Points/PointsEdit" to="." method="edit_points"]
[connection signal="button_down" from="EditMode/Exit" to="." method="edit_mode"]
[connection signal="button_down" from="EditMode/AddDiff" to="." method="add_diff"]
